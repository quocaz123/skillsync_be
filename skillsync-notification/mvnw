# ----------------------------------------------------------------------------
# Maven Wrapper startup script, POSIX
#
# Required files:
# - .mvn/wrapper/maven-wrapper.properties
#
# Optional files:
# - .mvn/wrapper/maven-wrapper.jar  (will be downloaded if missing)
# ----------------------------------------------------------------------------

set -euf

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
PROPS_FILE="$WRAPPER_DIR/maven-wrapper.properties"
JAR_FILE="$WRAPPER_DIR/maven-wrapper.jar"

if [ ! -f "$PROPS_FILE" ]; then
  echo "Missing $PROPS_FILE" 1>&2
  exit 1
fi

get_prop() {
  # usage: get_prop key file
  awk -F= -v key="$1" '
    $1==key { sub(/^[^=]*=/,""); gsub(/\r/,""); print; exit }
  ' "$2"
}

WRAPPER_URL=$(get_prop "wrapperUrl" "$PROPS_FILE" || true)
if [ -z "${WRAPPER_URL:-}" ]; then
  WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
fi

if [ ! -f "$JAR_FILE" ]; then
  mkdir -p "$WRAPPER_DIR"
  echo "Downloading Maven Wrapper jar..." 1>&2
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$WRAPPER_URL" -o "$JAR_FILE"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$WRAPPER_URL" -O "$JAR_FILE"
  else
    echo "Neither curl nor wget is available to download Maven Wrapper jar." 1>&2
    echo "Please install curl/wget or place maven-wrapper.jar at $JAR_FILE" 1>&2
    exit 1
  fi
fi

JAVA_CMD="${JAVA_HOME:-}/bin/java"
if [ -z "${JAVA_HOME:-}" ]; then
  JAVA_CMD="java"
fi

exec "$JAVA_CMD" \
  -Dmaven.multiModuleProjectDirectory="$BASE_DIR" \
  -classpath "$JAR_FILE" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
